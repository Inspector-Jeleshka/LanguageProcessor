<Window x:Class="GUI.Views.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:GUI.Views"
		xmlns:vm="clr-namespace:GUI.ViewModels"
		d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
		mc:Ignorable="d"
		Title="Компилятор" Height="450" Width="800" MinHeight="450" MinWidth="800">
	<Window.Resources>
		<Style TargetType="Image">
			<Setter Property="Height" Value="32" />
		</Style>
	</Window.Resources>
	<Window.InputBindings>
		<KeyBinding Gesture="Ctrl+N" Command="{Binding NewDocumentCommand}" />
		<KeyBinding Gesture="Ctrl+O" Command="{Binding OpenDocumentCommand}" />
		<KeyBinding Gesture="Ctrl+S" Command="{Binding SaveDocumentCommand}" />
		<KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveDocumentAsCommand}" />
		<KeyBinding Gesture="Alt+F4" Command="{Binding CloseApplicationCommand}" />
		<KeyBinding Gesture="F1" Command="{Binding ShowHelpCommand}" />
	</Window.InputBindings>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition MinHeight="50" />
			<RowDefinition Height="Auto" />
			<RowDefinition MinHeight="75" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition />
		</Grid.ColumnDefinitions>
		<Menu Grid.Row="0">
			<MenuItem Header="Файл">
				<MenuItem Header="Создать" Command="{Binding NewDocumentCommand}" InputGestureText="Ctrl+N" />
				<MenuItem Header="Открыть" Command="{Binding OpenDocumentCommand}" InputGestureText="Ctrl+O" />
				<MenuItem Header="Сохранить" Command="{Binding SaveDocumentCommand}" InputGestureText="Ctrl+S" />
				<MenuItem Header="Сохранить как" Command="{Binding SaveDocumentAsCommand}" InputGestureText="Ctrl+Shift+S" />
				<MenuItem Header="Выход" Command="{Binding CloseApplicationCommand}" InputGestureText="Alt+F4" />
			</MenuItem>
			<MenuItem Header="Правка">
				<MenuItem Header="Отменить" Command="Undo" />
				<MenuItem Header="Повторить" Command="Redo" />
				<MenuItem Header="Вырезать" Command="Cut" />
				<MenuItem Header="Копировать" Command="Copy" />
				<MenuItem Header="Вставить" Command="Paste" />
				<MenuItem Header="Удалить" Command="Delete" />
				<MenuItem Header="Выделить все" Command="SelectAll" />
			</MenuItem>
			<MenuItem Header="Текст">
				<MenuItem Header="Постановка задачи" />
				<MenuItem Header="Грамматика" />
				<MenuItem Header="Классификация грамматики" />
				<MenuItem Header="Метод анализа" />
				<MenuItem Header="Тестовый пример" />
				<MenuItem Header="Список литературы" />
				<MenuItem Header="Исходный код программы" />
			</MenuItem>
			<MenuItem Header="Пуск" Command="{Binding RunAllCommand}"/>
			<MenuItem Header="Справка">
				<MenuItem Header="Вызов справки" Command="{Binding ShowHelpCommand}" InputGestureText="F1" />
				<MenuItem Header="О программе" Command="{Binding AboutCommand}" />
			</MenuItem>
		</Menu>
		<ToolBar Grid.Row="1">
			<Button ToolTip="Создать" Command="{Binding NewDocumentCommand}">
				<Image Source="/Assets/file.png" />
			</Button>
			<Button ToolTip="Открыть" Command="{Binding OpenDocumentCommand}">
				<Image Source="/Assets/folder.png" />
			</Button>
			<Button ToolTip="Сохранить" Command="{Binding SaveDocumentCommand}">
				<Image Source="/Assets/save.png" />
			</Button>
			<Separator />
			<Button ToolTip="Отменить" Command="Undo">
				<Image Source="/Assets/left-arrow.png" />
			</Button>
			<Button ToolTip="Повторить" Command="Redo">
				<Image Source="/Assets/right-arrow.png" />
			</Button>
			<Button ToolTip="Копировать" Command="Copy">
				<Image Source="/Assets/copy.png" />
			</Button>
			<Button ToolTip="Вырезать" Command="Cut">
				<Image Source="/Assets/cut.png" />
			</Button>
			<Button ToolTip="Вставить" Command="Paste">
				<Image Source="/Assets/paste.png" />
			</Button>
			<Separator />
			<Button ToolTip="Пуск" Command="{Binding RunAllCommand}">
				<Image Source="/Assets/run.png" />
			</Button>
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Шаблон подстроки:" VerticalAlignment="Center" Margin="0,0,5,0"/>
				<ComboBox ItemsSource="{x:Static vm:MainViewModel.AllTemplates}"
						  SelectedItem="{Binding SelectedTemplate}" VerticalAlignment="Center" Width="160" />
			</StackPanel>
			<Separator />
			<Button ToolTip="Вызов справки" Command="{Binding ShowHelpCommand}">
				<Image Source="/Assets/question.png" />
			</Button>
			<Button ToolTip="О программе" Command="{Binding AboutCommand}">
				<Image Source="/Assets/information.png" />
			</Button>
		</ToolBar>
		<RichTextBox x:Name="rtb" Grid.Row="2" Margin="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
		<GridSplitter Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="Silver" Height="5" />
		<TabControl Grid.Row="4" Margin="5">
			<TabItem Header="Вывод лексера">
				<DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Lexemes}" IsReadOnly="True"
						  CanUserReorderColumns="False" CanUserResizeColumns="False" SelectionMode="Single">
					<DataGrid.Columns>
						<DataGridTextColumn Width=".5*" Header="Условный код" Binding="{Binding Code}" />
						<DataGridTextColumn Width="*" Header="Тип лексемы" Binding="{Binding Type}" />
						<DataGridTextColumn Width="*" Header="Лексема" Binding="{Binding Value}" />
						<DataGridTextColumn Width="*" Header="Местоположение" Binding="{Binding Location}" />
					</DataGrid.Columns>
					<DataGrid.InputBindings>
						<MouseBinding MouseAction="LeftDoubleClick" Command="{Binding NavigateToLexemeCommand}"
									  CommandParameter="{Binding SelectedItem,
									  RelativeSource={RelativeSource AncestorType=DataGrid}}" />
					</DataGrid.InputBindings>
				</DataGrid>
			</TabItem>
			<TabItem Header="Вывод парсера">
				<DataGrid AutoGenerateColumns="False" IsReadOnly="True"
						  CanUserReorderColumns="False" CanUserResizeColumns="False" SelectionMode="Single">
					<DataGrid.Columns>
						<DataGridTextColumn Width="*" Header="Неверный фрагмент" />
						<DataGridTextColumn Width="*" Header="Местоположение" />
						<DataGridTextColumn Width="*" Header="Описание ошибки" />
					</DataGrid.Columns>
				</DataGrid>
			</TabItem>
			<TabItem Header="Найденные подстроки">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>
					<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,2,0,2">
						<TextBlock Text="Число совпадений: " />
						<TextBlock Text="{Binding FoundSubstrings.Count}" />
					</StackPanel>
					<DataGrid Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding FoundSubstrings}" IsReadOnly="True"
						  CanUserReorderColumns="False" CanUserResizeColumns="False" SelectionMode="Single">
						<DataGrid.Columns>
							<DataGridTextColumn Width="*" Header="Найденная подстрока" Binding="{Binding Value}" />
							<DataGridTextColumn Width=".5*" Header="Начальная позиция" Binding="{Binding Location}" />
							<DataGridTextColumn Width=".5*" Header="Длина" Binding="{Binding Length}" />
						</DataGrid.Columns>
						<DataGrid.InputBindings>
							<MouseBinding MouseAction="LeftDoubleClick" Command="{Binding HighlightSubstringCommand}"
										  CommandParameter="{Binding SelectedItem,
										  RelativeSource={RelativeSource AncestorType=DataGrid}}" />
						</DataGrid.InputBindings>
					</DataGrid>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Window>
